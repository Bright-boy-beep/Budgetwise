{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "FLASK_APP": "run.py",
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "args": ["run", "--host=0.0.0.0", "--port=5000"],
      "jinja": true
    },
    {
      "name": "Frontend (Live Server — Chrome)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5500/frontend",
      "webRoot": "${workspaceFolder}/frontend"
    },
    {
      "name": "Python Tests (pytest)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "cwd": "${workspaceFolder}",
      "args": ["tests/backend/", "-v"]
    }
  ]
}
